# ==========================================
# PowerSentry Configuration
# ==========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Tapo Smart Plug ---
TAPO_IP=192.168.1.100
TAPO_EMAIL=your@email.com
TAPO_PASS=your_tapo_password

# --- Target PC ---
PC_MAC=AA:BB:CC:DD:EE:FF
PC_IP=192.168.1.50
PC_USER=your_user
SHUTDOWN_CMD=sudo shutdown -h now

# --- Virtual BMS — Battery Bank ---
BATTERY_VOLTAGE=24              # Nominal bank voltage (12, 24, 48)
BATTERY_AH=320                  # Total Ah capacity of the bank
CHARGE_AMPS=15                  # Charger / inverter charge current (A)
AVG_LOAD_WATTS=500              # Average AC load on the inverter (W)
MAX_OUTAGE_MINUTES=240          # Shutdown PC after this many minutes of outage (4 hrs)

# --- Lead-Acid BMS Tuning (optional — sensible defaults) ---
# INVERTER_EFFICIENCY=0.85      # DC→AC conversion efficiency (0.80–0.90 typical)
# SELF_DISCHARGE_PCT_MONTH=3.0  # Self-discharge %/month (sealed=3-5, flooded=10-15)
# USABLE_CAPACITY_FACTOR=0.80   # Fraction of total Ah that is usable (DoD limit)
# CHARGE_EFFICIENCY=0.80        # Coulombic efficiency of lead-acid charging

# --- Capacity Aging (optional — models permanent Ah loss over battery life) ---
# BATTERY_INSTALL_DATE=2024-01-15    # ISO date when the battery was installed
# CAPACITY_LOSS_PCT_PER_YEAR=5.0     # Permanent capacity loss %/year (sealed=3-5, flooded=5-7)

# --- Water Topup Reminder (flooded lead-acid only, set 0 to disable) ---
# WATER_TOPUP_INTERVAL_DAYS=90       # Remind every N days (0=disabled, for sealed/AGM/Gel)
